{
  "name": "htcalc",
  "version": "0.1.0",
  "description": "Heat treatment calculation utilities and process window workbench for ADI, steel austempering, and martempering.",
  "license": "MIT",
  "type": "module",
  "main": "dist/adi/index.js",
  "types": "dist/adi/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CoJoA13/HTCalc.git"
  },
  "bugs": {
    "url": "https://github.com/CoJoA13/HTCalc/issues"
  },
  "homepage": "https://github.com/CoJoA13/HTCalc#readme",
  "keywords": [
    "heat-treatment",
    "austempering",
    "martempering",
    "adi",
    "steel",
    "typescript",
    "vite"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "vite --host 127.0.0.1",
    "build": "npm run clean && npm run build:lib && npm run build:ui",
    "build:lib": "tsc -p tsconfig.build.json",
    "build:ui": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@phosphor-icons/web": "^2.1.2",
    "@types/node": "^26.1.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
