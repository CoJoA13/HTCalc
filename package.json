{
  "name": "htcalc",
  "version": "0.1.0",
  "description": "Heat treatment calculation utilities, starting with austempered ductile iron process windows.",
  "type": "module",
  "main": "dist/adi/index.js",
  "types": "dist/adi/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "vite --host 127.0.0.1",
    "build": "npm run clean && npm run build:lib && npm run build:ui",
    "build:lib": "tsc -p tsconfig.build.json",
    "build:ui": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@phosphor-icons/web": "^2.1.2",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
  }
}
